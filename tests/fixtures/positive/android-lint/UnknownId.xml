<?xml version="1.0" encoding="utf-8"?>
<!-- Positive fixture: layout_toLeftOf references @id/ghost, an id that is not
     declared anywhere (no android:id, no @+id/, no ids.xml entry). This is a
     dangling reference (typo or renamed id), so UnknownId fires Fatal. -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/button1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/button2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/ghost" />
</RelativeLayout>
