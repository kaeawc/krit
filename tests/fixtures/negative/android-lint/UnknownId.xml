<?xml version="1.0" encoding="utf-8"?>
<!-- Negative fixture: every @id/ reference resolves to an id declared in this
     layout, and the @android:id framework reference is always defined. The
     @+id/ create form is never a dangling reference. UnknownId stays silent. -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/anchor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/follower"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/anchor"
        android:layout_alignLeft="@android:id/text1" />
</RelativeLayout>
